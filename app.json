{
  "expo": {
    "name": "Battery Optimizer AI",
    "slug": "battery-optimizer-ai",
    "version": "4.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joyjet.optimizer",
      "infoPlist": {
        "NSCameraUsageDescription": "Required for UI calibration and hardware analysis.",
        "NSMicrophoneUsageDescription": "Used for hardware diagnostic tests."
      }
    },
    "android": {
      "package": "com.joyjet.optimizer",
      "versionCode": 42,
      "targetSdkVersion": 36,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "SYSTEM_ALERT_WINDOW",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-dev-client",
      "expo-battery",
      "expo-network",
      "expo-task-manager",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AI to analyze UI screenshots for battery drain."
        }
      ],
      [
        "expo-screen-capture",
        {
          "addAndroidScreenshotsPermission": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
