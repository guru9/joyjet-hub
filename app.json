{
  "expo": {
    "name": "Battery Optimizer AI",
    "slug": "joyjet-hub",
    "version": "4.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joyjet.optimizer"
    },
    "android": {
      "package": "com.joyjet.optimizer",
      "versionCode": 42,
      "targetSdkVersion": 35,
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "SYSTEM_ALERT_WINDOW",
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-dev-client",
      "expo-splash-screen",
      "@config-plugins/react-native-webrtc",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "targetSdkVersion": 36
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Battery Optimizer AI to access your camera",
          "microphonePermission": "Allow Battery Optimizer AI to access your microphone"
        }
      ],
      "./withAndroidStrings.js"
    ],
    "extra": {
      "eas": {
        "projectId": "6adb5db6-de83-4339-af7b-17c91a68079d"
      }
    }
  }
}
