{
  "expo": {
    "name": "Battery Optimizer",
    "slug": "battery-optimizer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.sys.battery.optimizer",
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "BOOT_COMPLETED",
          "category": "DEFAULT"
        }
      ]
    },
    "plugins": [
      [
        "expo-location",
        { "locationAlwaysPermission": "Allow Battery Optimizer to sync satellite data." }
      ],
      "expo-task-manager",
      "expo-notifications"
    ]
  }
}
