{
  "expo": {
    "name": "Battery Optimizer AI",
    "slug": "joyjet-hub",
    "version": "4.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joyjet.optimizer"
    },
    "android": {
      "package": "com.joyjet.optimizer",
      "versionCode": 42,
      "targetSdkVersion": 36,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "foregroundService": [
              {
                "type": "mediaProjection",
                "notification": {
                  "title": "Battery Optimizer Active",
                  "body": "Monitoring hardware performance..."
                }
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
